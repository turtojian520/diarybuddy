# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# Notion OAuth (create a Public integration at https://www.notion.so/profile/integrations)
# These are set on Vercel (Project → Settings → Environment Variables), not committed.
NOTION_OAUTH_CLIENT_ID=your_notion_oauth_client_id
NOTION_OAUTH_CLIENT_SECRET=your_notion_oauth_client_secret
# Must match the redirect URI registered in the Notion integration.
NOTION_OAUTH_REDIRECT_URI=https://diarybuddy.vercel.app/api/notion/oauth/callback
# 32-byte key (base64). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NOTION_TOKEN_ENCRYPTION_KEY=your_32_byte_base64_key
